{
  "compilerOptions": {
    "baseUrl": ".",                     // ⭐ REQUIRED FOR ALIASES TO WORK ON VERCEL
    "allowJs": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/*": ["src/*"]                  // ⭐ Alias now works everywhere
    },
    "skipLibCheck": true,
    "strictNullChecks": false
  },
  "include": ["src"],                   // ⭐ Ensures Vercel includes your source files
  "exclude": ["node_modules"],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ]
}
